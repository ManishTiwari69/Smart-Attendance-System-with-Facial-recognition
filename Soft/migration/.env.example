# ─── SmartHospital Environment Configuration ──────────────────────────────────
# Copy this to .env and fill in values. Never commit .env to version control.

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development / quick start):
DATABASE_URL=sqlite:///smarthospital.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/smarthospital_db

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ── Face Recognition ─────────────────────────────────────────────────────────
FACE_EMBEDDING_THRESHOLD=0.75      # Cosine similarity threshold (0–1). Lower = stricter.
FACE_EMBEDDING_DIM=512             # FaceNet InceptionResnetV1 output dimension
MTCNN_IMAGE_SIZE=160               # MTCNN crop size fed to FaceNet
MTCNN_MIN_FACE_SIZE=40             # Minimum detectable face size (px)
MTCNN_THRESHOLDS=0.6,0.7,0.7      # MTCNN P-net, R-net, O-net thresholds
FACE_STORE_PATH=./face_store        # Directory for raw face images (audit/retrain)
MAX_FACE_ENROLLMENT_IMAGES=5       # How many face captures to average for enrollment

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_FACE_AUTH=10            # Max face auth attempts per minute per IP
RATE_LIMIT_PIN=5                   # Max PIN attempts before lockout
PIN_LOCKOUT_MINUTES=15
AUDIT_LOG_RETENTION_DAYS=365

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ── Storage ──────────────────────────────────────────────────────────────────
REPORT_UPLOAD_PATH=./uploads/reports
MAX_UPLOAD_SIZE_MB=50
